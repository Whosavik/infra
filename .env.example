# =============================================================================
# Azure Service Principal credentials
# Used by the azurerm provider and the backend for authentication.
# =============================================================================
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# =============================================================================
# tfstate backend
# Fill in BACKEND_SA after running: task bootstrap
# The same values are also exposed as TF_VAR_backend_* so that prod/ and
# nonprod/ can reference shared state via terraform_remote_state.
# =============================================================================
BACKEND_RG=rg-tfstate
BACKEND_SA=
BACKEND_CONTAINER=tfstate

# =============================================================================
# Common infrastructure
# =============================================================================
TF_VAR_location=australiasoutheast

# =============================================================================
# Hub VNet (existing — OpenTofu reads this VNet, it does not create it)
# =============================================================================
TF_VAR_hub_vnet_name=cc-vnet-hub
TF_VAR_hub_vnet_resource_group=cc-rg-hub

# A free /28 CIDR block within the hub VNet for the DNS resolver subnet.
# Example: 10.0.255.240/28
TF_VAR_hub_resolver_subnet_prefix=10.66.0.208/28

# JSON list of existing private DNS zone names to link to the hub VNet.
# Add one entry per service type your clusters need to reach.
# Example: ["privatelink.documents.azure.com","privatelink.blob.core.windows.net"]
TF_VAR_private_dns_zone_names=[
  "privatelink.documents.azure.com",
  "privatelink.blob.core.windows.net"
]

# =============================================================================
# Shared resources
# =============================================================================

# Globally unique name for the Container Registry (alphanumeric only, 5-50 chars)
TF_VAR_acr_name=cc-acr

# Globally unique Key Vault name (3-24 chars, alphanumeric and hyphens)
TF_VAR_key_vault_name=

# =============================================================================
# Prod cluster spoke VNet
# Choose an address space that does not overlap with the hub or other spokes.
# =============================================================================
TF_VAR_prod_vnet_address_space=10.67.0.0/16
TF_VAR_prod_node_subnet_prefix=10.67.1.0/24

# Prod node pool sizing
PROD_VM_SIZE=Standard_B2s
PROD_MIN_NODES=2
PROD_MAX_NODES=5

# =============================================================================
# Nonprod cluster spoke VNet
# =============================================================================
TF_VAR_nonprod_vnet_address_space=10.68.0.0/16
TF_VAR_nonprod_node_subnet_prefix=10.68.1.0/24

# Nonprod node pool sizing
NONPROD_VM_SIZE=Standard_B2s
NONPROD_MIN_NODES=1
NONPROD_MAX_NODES=3

# =============================================================================
# DNS + nginx ILB (per-env)
# nginx ILB IPs are static IPs from each cluster's AKS subnet CIDR.
# =============================================================================
TF_VAR_parent_domain=busstop.dev

NONPROD_CLUSTER_SUBDOMAIN=npe
NONPROD_NGINX_ILB_IP=10.68.1.100

PROD_CLUSTER_SUBDOMAIN=prd
PROD_NGINX_ILB_IP=10.67.1.100
